# ============================================================
# SENTINEL — Environment Configuration
# Copy to .env and fill in values before running:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=change-me

# --- JWT ---
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
APP_NAME=SENTINEL
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:8088,https://yourdomain.com

# --- Frontend (build-time) ---
NEXT_PUBLIC_API_URL=http://localhost:8088/api
NEXT_PUBLIC_WS_URL=ws://localhost:8088/ws

# --- API Keys (all optional — system works without them) ---
ALIENVAULT_OTX_KEY=
GREYNOISE_API_KEY=
SHODAN_API_KEY=
IPINFO_TOKEN=
HUNTER_IO_KEY=
NEWSAPI_KEY=
OPENCAGE_API_KEY=
HAVEIBEENPWNED_KEY=
SECURITYTRAILS_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
INTELX_API_KEY=
YOUTUBE_API_KEY=

# --- Telegram Integration ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Email Notifications ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=sentinel@yourdomain.com

# --- Report Storage ---
REPORTS_DIR=/app/reports
